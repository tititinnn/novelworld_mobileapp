<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="18dp"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/img_book_cover"
        android:layout_width="68dp"
        android:layout_height="102dp"
        android:scaleType="centerCrop"
        tools:src="@android:drawable/ic_menu_gallery" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txt_book_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Bên nhau trọn đời" />

        <TextView
            android:id="@+id/txt_chapter_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#333333"
            android:textSize="13sp"
            tools:text="Lần xem trước: Chương 10" />

        <TextView
            android:id="@+id/txt_view_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#333333"
            android:textSize="13sp"
            tools:text="Chương mới nhất 97" />
    </LinearLayout>
</LinearLayout>